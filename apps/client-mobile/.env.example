# Mobile-specific env. Copy to apps/client-mobile/.env.local for local dev.
# All public values for Expo must be prefixed EXPO_PUBLIC_*.

# Supabase project
# Dev (local Supabase docker on the same Mac):  http://127.0.0.1:54321
# Production (remote project):                  https://mjinvgsnhxulcquixbiv.supabase.co
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Optional — used by demo flows that load a default tenant
EXPO_PUBLIC_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000000

# Base URL for the web API the mobile client calls.
# Dev (web running locally on the same Mac as the simulator):  http://localhost:3000
# Dev (web running locally + Android emulator):                http://10.0.2.2:3000
# Vercel preview / staging:                                    https://<branch-preview>.vercel.app
# Production (Vercel-natural URL, used until a custom domain
# is decided — the final production domain is still TBD):      https://companeros-en-ruta.vercel.app
EXPO_PUBLIC_WEB_API_BASE=http://localhost:3000

# ---------------------------------------------------------------------------
# EAS Build env vars (DO NOT commit production values to .env.local)
# ---------------------------------------------------------------------------
# For production / preview builds, set these via EAS environments:
#   pnpm exec eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_URL --value "https://mjinvgsnhxulcquixbiv.supabase.co"
#   pnpm exec eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value "<anon-key>"
#   pnpm exec eas env:create --environment production --name EXPO_PUBLIC_WEB_API_BASE --value "https://companerosenruta.com"
#   pnpm exec eas env:create --environment production --name EXPO_PUBLIC_DEMO_TENANT_ID --value "<tenant-id>"
# Repeat with --environment preview for TestFlight / internal builds.

{
  "expo": {
    "name": "Compañeros en Ruta",
    "slug": "companeros-en-ruta",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "companeros",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.companeros.enruta",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSAllowsArbitraryLoadsInWebContent": false
        },
        "NSLocationWhenInUseUsageDescription": "Necesitamos tu ubicación para registrar el check-in en el cliente.",
        "NSCameraUsageDescription": "Necesitamos la cámara para tomar evidencia fotográfica de la visita.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceder a tus fotos para adjuntar evidencia de la visita."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.companeros.enruta",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necesitamos tu ubicación para registrar el check-in en el cliente."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Acceso a tus fotos para adjuntar evidencia de la visita.",
          "cameraPermission": "Acceso a la cámara para capturar evidencia de la visita."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

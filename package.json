    "@types/node": "^20.19.30",
    "jest": "^30.2.0",
    "pg": "^8.18.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}

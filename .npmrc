# Hoist all transitive deps to the root node_modules.
# Required for the apps/mobile (Expo + Metro) workspace — Metro can't see
# transitive peer deps under pnpm's strict isolation, and listing them all
# as direct deps of apps/mobile is brittle (every Expo SDK bump breaks).
# apps/web is unaffected: it uses TypeScript's local-first module resolution
# from apps/web/node_modules.
public-hoist-pattern[]=*
